{
  "remote.SSH.remotePlatform": {
    "pcbubs8": "linux",
    "172.29.110.249": "linux",
    "pcbubs10.realsil.com.cn": "linux"
  },
  // program language configs
  "[c]": {
    "editor.tabSize": 8,
    "editor.insertSpaces": false,
    "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd"
  },
  "[cpp]": {
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd"
  },
  "clangd.arguments": [
    "--log=error",
    "--header-insertion=never",
    "--query-driver=/**/*",
    "--clang-tidy"
  ],
  "clangd.onConfigChanged": "restart",
  "C_Cpp.intelliSenseEngine": "disabled",
  "[python]": {
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.codeActionsOnSave": {
      "source.organizeImports.isort": "explicit"
    }
  },
  "isort.args": [
    "--profile",
    "black"
  ],
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features",
    "editor.tabSize": 2,
    "editor.insertSpaces": true
  },
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features",
    "editor.tabSize": 2,
    "editor.insertSpaces": true
  },
  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer",
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit",
      "source.fixAll": "explicit"
    },
    "editor.inlayHints.enabled": "on"
  },
  "rust-analyzer.check.command": "clippy",
  // editor configs
  "editor.fontSize": 15,
  "editor.insertSpaces": false,
  "editor.tabSize": 8,
  "editor.suggestSelection": "first",
  "editor.unicodeHighlight.invisibleCharacters": false,
  "editor.formatOnPaste": true,
  "editor.formatOnType": true,
  "editor.formatOnSave": true,
  "editor.tabCompletion": "onlySnippets",
  "editor.detectIndentation": false,
  "editor.fontLigatures": true,
  "editor.fontFamily": "Fira Code, Consolas, 'Courier New', monospace",
  "editor.lineHeight": 1.5,
  "editor.lineNumbers": "relative",
  "editor.rulers": [
    80
  ],
  "editor.hover.delay": 1000,
  "editor.semanticHighlighting.enabled": true,
  "editor.inlayHints.enabled": "offUnlessPressed",
  // files
  "files.trimTrailingWhitespace": true,
  "files.trimFinalNewlines": true,
  "files.insertFinalNewline": true,
  "files.eol": "\n",
  // theme and workbench configs
  "workbench.activityBar.orientation": "vertical",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.preferredLightColorTheme": "Atom One Light",
  "workbench.colorTheme": "Atom One Light",
  "workbench.colorCustomizations": {
    "[Atom One Light]": {
      "editor.background": "#F7F7F7",
      "editor.selectionBackground": "#526FFF26",
      "sideBar.background": "#EFEFEF",
      "activityBar.background": "#F7F7F7",
      "editorRuler.foreground": "#E0E0E0"
    }
  },
  "editor.tokenColorCustomizations": {
    "[Atom One Light]": {
      "textMateRules": [
        {
          "scope": "entity.name.function.preprocessor",
          "settings": {
            "foreground": "#986801"
          }
        },
        {
          "scope": "variable.parameter",
          "settings": {
            "foreground": "#0184BC"
          }
        }
      ]
    }
  },
  /** terminal configs **/
  "terminal.integrated.env.linux": {
    "VSCODE_INTEGRATED_TERMINAL": "1"
  },
  "terminal.integrated.env.osx": {
    "VSCODE_INTEGRATED_TERMINAL": "1"
  },
  "terminal.integrated.defaultProfile.windows": "Git Bash",
  "terminal.integrated.defaultProfile.linux": "zsh",
  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.useWslProfiles": false,
  /** MISC configs **/
  "git.autofetch": true,
  "update.enableWindowsBackgroundUpdates": false,
  "remote.autoForwardPortsSource": "hybrid",
  "diffEditor.ignoreTrimWhitespace": false,
  "explorer.openEditors.sortOrder": "alphabetical",
  /** extension configs **/
  // VIM configs
  "vim.useSystemClipboard": true,
  "vim.incsearch": true,
  "vim.hlsearch": true,
  "vim.easymotion": true,
  "vim.leader": "<space>",
  "vim.insertModeKeyBindings": [
    {
      "before": [
        "j",
        "j"
      ],
      "after": [
        "<Esc>"
      ]
    }
  ],
  "vim.normalModeKeyBindings": [
    {
      "before": [
        "<Enter>"
      ],
      "after": [
        "o",
        "<Esc>"
      ]
    },
    {
      "before": [
        "<C-v>"
      ],
      "after": [
        "i",
        "<C-v>",
        "<Esc>"
      ]
    }
  ],
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": [
        "g",
        "r"
      ],
      "commands": [
        "editor.action.goToReferences"
      ]
    }
  ],
  "vim.handleKeys": {
    "<C-a>": false,
    "<C-c>": false,
    "<C-x>": false,
    "<C-f>": false,
    "<C-h>": false,
    "<C-n>": false,
    "<C-p>": false,
    "<C-y>": false,
    "<C-g>": false,
    "<C-l>": false,
    "<C-b>": false,
    "<C-w>": false,
    "<C-k>": false,
    "<C-v>": false,
    "<C-s>": false,
    "<C-m>": false,
    "<Shift-Tab>": false
  },
  "vim.commandLineModeKeyBindingsNonRecursive": [],
  // TODO tree
  "todo-tree.general.tags": [
    "???",
    "NOTE:",
    "Note:",
    "BUG:",
    "Bug:",
    "HACK:",
    "Hack:",
    "FIXME:",
    "Fixme:",
    "TODO:",
    "Todo:"
  ],
  "todo-tree.highlights.defaultHighlight": {
    "icon": "smiley",
    "type": "tag",
    "foreground": "#ffffff",
    "background": "#47da03",
    "opacity": 50,
    "iconColour": "#47da03"
  },
  "todo-tree.highlights.customHighlight": {
    "TODO:": {
      "icon": "check",
      "foreground": "#ffffff",
      "background": "#FFA500",
      "iconColour": "#FFA500"
    },
    "Todo:": {
      "icon": "check",
      "foreground": "#ffffff",
      "background": "#FFA500",
      "iconColour": "#FFA500"
    },
    "FIXME:": {
      "icon": "info",
      "foreground": "#ffffff",
      "background": "#FF1493",
      "iconColour": "#FF1493"
    },
    "Fixme:": {
      "icon": "info",
      "foreground": "#ffffff",
      "background": "#FF1493",
      "iconColour": "#FF1493"
    },
    "BUG:": {
      "icon": "alert",
      "foreground": "#ffffff",
      "background": "#ff1414",
      "iconColour": "#ff1414"
    },
    "HACK:": {
      "icon": "alert",
      "foreground": "#ffffff",
      "background": "#0099ff",
      "iconColour": "#0099ff"
    }
  },
  "todo-tree.regex.regex": "(//|^\\s*\\*|#|<!--|;|/\\*|^|^[ \\t]*(-|\\d+.))\\s*($TAGS)",
  // multiCommand configs
  "multiCommand.commands": [
    {
      "command": "multiCommand.GoToReference",
      "interval": 50,
      "sequence": [
        "revealReference",
        "closeReferenceSearch",
        "extension.vim_escape"
      ]
    },
    {
      "command": "multiCommand.ExitSearch",
      "interval": 50,
      "sequence": [
        "closeFindWidget",
        "extension.vim_escape"
      ]
    },
    {
      "command": "multiCommand.jump",
      "interval": 50,
      "sequence": [
        "revealReference",
        "closeReferenceSearch",
        "extension.vim_escape"
      ]
    }
  ],
  // markdownlint
  "markdownlint.config": {
    "MD010": false,
    "MD014": false,
    "MD033": false,
    "MD034": false,
    "MD025": false,
    "MD045": false,
    "MD036": false,
    "MD038": false
  },
  // cmake
  "cmake.showOptionsMovedNotification": false,
  "cmake.configureOnOpen": true,
  "cmake.showConfigureWithDebuggerNotification": false,
  // cursor
  "cursor.cpp.enablePartialAccepts": true,
  "cursor.composer.usageSummaryDisplay": "always",
  // gitlens
  "gitlens.codeLens.enabled": false,
  "gitlens.views.commits.showStashes": true,
  "gitlens.views.scm.grouped.views": {
    "commits": true,
    "branches": true,
    "remotes": true,
    "stashes": true,
    "tags": true,
    "worktrees": true,
    "contributors": true,
    "fileHistory": true,
    "repositories": true,
    "searchAndCompare": false,
    "launchpad": false
  }
}
